---
import BlankLayout from '@/layouts/BlankLayout.astro'

const pageTitle = '404 — Page Not Found'
---

<BlankLayout title={pageTitle} description='The page you are looking for does not exist.' noindex nofollow>
  <div class='flex h-screen flex-col items-center justify-center gap-6 p-6'>
    <h1 class='text-6xl font-bold'>404</h1>
    <p class='text-muted-foreground text-xl text-center'>We couldn&apos;t find the page you are looking for</p>
    <a href='/' class='bg-primary text-primary-foreground rounded-lg px-6 py-3 font-medium hover:bg-primary/90'>Go back to home</a>
  </div>
</BlankLayout>
