---
import Layout from '@/layouts/Layout.astro'
import { Badge } from '@/components/ui/badge'

type Release = {
  version: string
  date: string
  is_unreleased?: boolean
  release_name?: string
}

let releases: Release[] = []

try {
  const fs = await import('node:fs')
  const path = await import('node:path')
  const jsonPath = path.resolve(process.cwd(), 'src/data/releases.json')
  if (fs.existsSync(jsonPath)) {
    const raw = fs.readFileSync(jsonPath, 'utf-8')
    const parsed = JSON.parse(raw)
    releases = (parsed.releases || []).reverse()  // newest first
  }
} catch (e) {
  console.log('No releases.json found')
}

const modern = releases.filter(r => r.version.startsWith('1.'))
const legacy = releases.filter(r => !r.version.startsWith('1.'))

const pageTitle = 'All Versions — version.rs'
---

<Layout title={pageTitle} description='Browse all Rust compiler releases.'>
  <div class='mx-auto max-w-3xl px-4 py-12'>
    <a href='/' class='text-muted-foreground hover:text-primary text-sm mb-6 inline-block'>&larr; Back</a>
    <h1 class='text-3xl font-bold mb-2'>All Versions</h1>
    <p class='text-muted-foreground mb-8'>{releases.length} releases total</p>

    <div class='space-y-1'>
      {modern.map(r => (
        <a
          href={`/v/${r.version}`}
          class='flex items-center justify-between rounded-lg px-4 py-2.5 hover:bg-muted/50 transition-colors'
        >
          <div class='flex items-center gap-24'>
            <span class='font-medium'>Rust {r.version}</span>
            {r.is_unreleased && r.release_name === 'nightly' && (
              <Badge variant='outline' class='bg-purple-600/10 text-purple-600 dark:bg-purple-400/10 dark:text-purple-400 border-purple-600/20 text-[10px] px-1.5 py-0'>Nightly</Badge>
            )}
            {r.is_unreleased && r.release_name === 'beta' && (
              <Badge variant='outline' class='bg-amber-600/10 text-amber-600 dark:bg-amber-400/10 dark:text-amber-400 border-amber-600/20 text-[10px] px-1.5 py-0'>Beta</Badge>
            )}
          </div>
          <span class='text-muted-foreground text-sm shrink-0'>
            {new Date(r.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </span>
        </a>
      ))}
    </div>

    {legacy.length > 0 && (
      <details class='mt-8'>
        <summary class='cursor-pointer text-muted-foreground hover:text-primary text-sm font-medium'>
          Legacy versions (0.x) — {legacy.length} releases
        </summary>
        <div class='mt-3 space-y-1'>
          {legacy.map(r => (
            <a
              href={`/v/${r.version}`}
              class='flex items-center justify-between rounded-lg px-4 py-2 hover:bg-muted/50 transition-colors'
            >
              <span class='font-medium'>Rust {r.version}</span>
              <span class='text-muted-foreground text-sm'>
                {new Date(r.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </a>
          ))}
        </div>
      </details>
    )}
  </div>
</Layout>
